// Load required plugins
load "msh3"
load "TetGen"
load "medit"
include "MeshSurface.idp"

// Geometry parameters
real rSphere = 0.5;
real rCyl    = 0.3;
real lenCyl  = 1.5;
real centerDist = 1.8;
real meshSize = 0.1;

real xLeft  = -centerDist/2;
real xRight =  centerDist/2;

// 1. Create the two spheres (surface meshes)
meshS sphereLeft  = Sphere(rSphere, meshSize, 1, 1, xLeft, 0.0, 0.0);
meshS sphereRight = Sphere(rSphere, meshSize, 2, 1, xRight, 0.0, 0.0);

// 2. Build the cylinder surface manually
int nTheta = 40;          // number of points around circumference
int nZ = 20;              // number of points along length

real zStart = -lenCyl/2;
real zEnd   =  lenCyl/2;

// 2.1 Create the lateral surface by extruding a 2D circle in Z
// Define a 2D circular mesh (cross-section of the cylinder)
border circleBorder(t=0, 2*pi) { x = rCyl*cos(t); y = rCyl*sin(t); }
mesh ThDisk = buildmesh(circleBorder(nTheta));

// Extrude the disk into a 3D cylinder (volume mesh)
mesh3 ThCylVol = buildlayers(ThDisk, nZ, [zStart, zEnd], labelmid=3);

// 2.2 Extract the surface mesh of the cylinder from the volume mesh
meshS ThCylSurf = extract(ThCylVol);

// 3. Assemble the full surface mesh
meshS dumbbellSurf = sphereLeft + sphereRight + ThCylSurf;

// 4. Generate the volume tetrahedral mesh using TetGen
real[int, int] regions = [[0.0, 0.0, 0.0, 1, meshSize^3]];
mesh3 Th3D = tetg(dumbbellSurf, switch="pqaAAYYQ", nbofregions=1, regionlist=regions);

// 5. Show the mesh (command to display)
plot(Th3D, wait=true, cmm="Dumbbell mesh");
// Optional: medit("Dumbbell mesh", Th3D);